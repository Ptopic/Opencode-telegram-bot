{
  "name": "@opencode-telegram/code-search",
  "version": "0.1.0",
  "type": "module",
  "description": "Code search/RAG tool with semantic search, LanceDB vector storage, Chonkiejs AST chunking, and live file watching",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx watch src/cli.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@chonkiejs/core": "^0.0.9",
    "@lancedb/lancedb": "^0.27.0",
    "@langchain/community": "^1.1.27",
    "apache-arrow": "18.1.0",
    "axios": "^1.6.0",
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "openai": "^6.34.0",
    "tree-sitter-wasms": "^0.1.13",
    "uuid": "^9.0.0",
    "voyageai": "^0.2.1",
    "web-tree-sitter": "^0.26.8",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
