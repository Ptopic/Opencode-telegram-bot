{
  "name": "opencode-telegram",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "opencode-telegram": "./bin/opencode-telegram.js"
  },
  "scripts": {
    "dev": "node ./bin/opencode-telegram.js dev",
    "attach": "node ./bin/opencode-telegram.js attach",
    "kill-all": "node ./bin/opencode-telegram.js kill-all",
    "start": "node ./bin/opencode-telegram.js",
    "start:watch": "nodemon --watch bot.js --watch bin/opencode-telegram.js --exec \"node ./bin/opencode-telegram.js\"",
    "test": "node --test"
  },
	"dependencies": {
		"@grammyjs/parse-mode": "^2.3.0",
		"axios": "^1.6.0",
		"difit": "^3.1.16",
		"grammy": "^1.38.3"
	},
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
