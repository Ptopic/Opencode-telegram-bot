# Telegram bot token from @BotFather
TELEGRAM_TOKEN=

# Optional: custom OpenCode server URL (defaults to http://127.0.0.1:4096)
# OPENCODE_BASE_URL=http://127.0.0.1:4096

# Optional: custom instance port range
# OPENCODE_INSTANCE_PORT_START=50000
# OPENCODE_INSTANCE_PORT_END=59999

# Optional: interaction timeout in ms (default 120000)
# OPENCODE_INTERACTION_TIMEOUT_MS=120000

# Optional: live sync interval in ms (default 5000)
# OPENCODE_TELEGRAM_LIVE_SYNC_INTERVAL_MS=5000
